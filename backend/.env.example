# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=
JWT_EXPIRE_MINUTES=480
APP_NAME=amzur-ai-chat
ENVIRONMENT=development

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=
SQL_ALLOWED_TABLES=users,chat_threads,chat_messages,attachments
SQL_QUERY_MAX_ROWS=100

# ── Amzur LiteLLM Proxy ───────────────────────────────────────────────────────
LITELLM_PROXY_URL=https://litellm.amzur.com
LITELLM_API_KEY=
LLM_MODEL=gemini/gemini-2.5-flash
LITELLM_EMBEDDING_MODEL=text-embedding-3-large
IMAGE_GEN_MODEL=gemini/imagen-4.0-fast-generate-001
ARXIV_MAX_RESULTS=8
RESEARCH_AGENT_MAX_ITERATIONS=4

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ── Google Sheets service account ────────────────────────────────────────────
# Paste the full JSON content of your service account key file as a single line
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── File uploads ──────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=20
DATAFRAME_MAX_UPLOAD_MB=10
UPLOAD_DIR=./uploads
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,image/bmp,image/svg+xml,video/mp4,video/webm,video/ogg,text/plain,text/csv,text/tab-separated-values,application/csv,application/vnd.ms-excel,text/x-python,text/x-java-source,text/javascript,application/javascript,text/x-c,text/x-c++src,application/pdf,text/x-typescript,text/markdown,application/x-tex

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173
